<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Lab7_BlackBox_Suite" parallel="none">

    <parameter name="baseUrl" value="https://www.saucedemo.com"/>
    <parameter name="browser" value="chrome"/>

    <test name="Functional Regression Tests">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>

        <classes>
            <class name="dtm.tests.TC_DangNhapTest"/>
            <class name="dtm.tests.TC_GioHangTest"/>
            <class name="dtm.tests.TC_CheckoutTest"/>
            <class name="dtm.tests.TC_TimKiemTest"/>
        </classes>
    </test>
</suite>